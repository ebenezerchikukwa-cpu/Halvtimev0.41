# Kopier denne filen til ".env" og fyll inn dine egne verdier.

PORT=3000
NODE_ENV=development

# Lang, tilfeldig tekst som signerer innloggingscookien.
SESSION_SECRET=bytt-ut-med-en-lang-tilfeldig-streng

# Admin logger inn via Min side-skjemaet med denne e-posten + passordet.
# Da sendes man rett til admin-panelet (/admin.html).
ADMIN_EPOST=admin@halvtime.no
ADMIN_PASSORD=halvtime567
